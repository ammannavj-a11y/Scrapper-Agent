# GUVID v3.0 — Environment Configuration
# Copy to .env and set real values

# Platform
COUNTRY_CODE=IN
ENVIRONMENT=development

# Database
DB_ROOT_PASSWORD=change_me_db_password

# Security
JWT_SECRET=change_me_jwt_secret_minimum_32_characters
GUVID_SIGNING_PRIVATE_KEY=       # ECDSA P-256 PEM (auto-generated in dev)
NATIONAL_ID_SALT=change_me_salt
AES_KEY=                          # 32-byte hex (SHA256 of passphrase if empty)

# MinIO
MINIO_USER=minioadmin
MINIO_PASS=minioadmin123

# Grafana
GRAFANA_PASS=admin123

# Fabric (production)
FABRIC_ORG=Org1MSP
FABRIC_CHANNEL=guvichannel
FABRIC_CHAINCODE=guvichaincode
FABRIC_PEER_ENDPOINT=peer0.org1.example.com:7051

# Country API base URLs (leave as mock for development)
UIDAI_API_BASE=http://mock-integrations:8099/in
NSDL_API_BASE=http://mock-integrations:8099/in
EPFO_API_BASE=http://mock-integrations:8099/in
NAD_API_BASE=http://mock-integrations:8099/in
IRS_TIN_API_BASE=http://mock-integrations:8099/us
SSA_API_BASE=http://mock-integrations:8099/us
GOVUK_ONELOGIN_BASE=http://mock-integrations:8099/gb
