# PrivacyShield OSS — NO external API keys required for dev.
# Copy to .env and set SECRET_KEY.

ENVIRONMENT=development
DEBUG=true
SECRET_KEY=CHANGE_ME_GENERATE_64_CHARS

DATABASE_URL=postgresql+asyncpg://privacyshield:devpassword@localhost:5432/privacyshield
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
BACKEND_CORS_ORIGINS=http://localhost:3000

# SearXNG (replaces Google Custom Search — no API key)
SEARXNG_URL=http://localhost:8888

# Mailhog dev SMTP (replaces SendGrid — no API key)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_STARTTLS=false
FROM_EMAIL=noreply@privacyshield.local
FROM_NAME=PrivacyShield

# MinIO (replaces AWS S3)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=privacyshield-exports
MINIO_SECURE=false

# HashiCorp Vault OSS (replaces AWS Secrets Manager)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token

# GlitchTip (replaces Sentry SaaS — self-hosted)
SENTRY_DSN=
